FROM rust:1.89-bookworm

RUN apt-get update && apt-get install -y \
    protobuf-compiler \
    cmake \
    pkg-config \
    libssl-dev \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
VOLUME ["/workspace"]

CMD ["cargo", "watch", "-x", "run --bin ifran-server --all-features"]

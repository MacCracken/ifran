# Runtime-only container for CI/CD releases.
# Uses pre-built binaries from the build-release job instead of compiling
# inside the container. This avoids QEMU-emulated Rust compilation for
# cross-arch builds, reducing build time from 30+ minutes to ~1 minute.
#
# Expects binaries staged into bin/<arch>/ in the build context:
#   bin/amd64/synapse, bin/amd64/synapse-api
#   bin/arm64/synapse, bin/arm64/synapse-api
FROM debian:bookworm-slim

ARG VERSION
ARG TARGETARCH

LABEL org.opencontainers.image.title="Synapse"
LABEL org.opencontainers.image.description="LLM controller for pulling, managing, and training language models"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.source="https://github.com/MacCracken/synapse"
LABEL org.opencontainers.image.licenses="MIT"

RUN apt-get update && apt-get install -y \
    ca-certificates \
    tini \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -g 1000 synapse && \
    useradd -u 1000 -g synapse -m -s /bin/bash synapse

RUN mkdir -p /var/lib/synapse/models /var/lib/synapse/checkpoints /var/lib/synapse/cache && \
    chown -R synapse:synapse /var/lib/synapse

# Copy arch-specific pre-built binaries
COPY bin/${TARGETARCH}/synapse-api /usr/local/bin/synapse-server
COPY bin/${TARGETARCH}/synapse /usr/local/bin/synapse

USER synapse
EXPOSE 8420 8421

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD ["/usr/local/bin/synapse", "status"] || exit 1

ENTRYPOINT ["tini", "--"]
CMD ["synapse-server"]

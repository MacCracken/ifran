# Runtime-only container for CI/CD releases.
# Uses pre-built binaries from the build-release job instead of compiling
# inside the container. This avoids QEMU-emulated Rust compilation for
# cross-arch builds, reducing build time from 30+ minutes to ~1 minute.
#
# Expects binaries staged into bin/<arch>/ in the build context:
#   bin/amd64/ifran, bin/amd64/ifran-server
#   bin/arm64/ifran, bin/arm64/ifran-server
#
# Base: AGNOS (agnosticos) — our AI/ML operating system layer.
# Provides GLIBC 2.41+ (Debian trixie), seccomp, landlock, and
# shared runtime conventions across the ecosystem.
FROM ghcr.io/maccracken/agnosticos:latest

ARG VERSION
ARG TARGETARCH

LABEL org.opencontainers.image.title="Ifran"
LABEL org.opencontainers.image.description="LLM controller for pulling, managing, and training language models"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.source="https://github.com/MacCracken/ifran"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.base.name="ghcr.io/maccracken/agnosticos:latest"

# AGNOS base includes ca-certificates and tini; just create the ifran user/dirs
USER root
RUN groupadd -g 1002 ifran && \
    useradd -u 1002 -g ifran -m -s /bin/bash ifran

RUN mkdir -p /var/lib/ifran/models /var/lib/ifran/checkpoints /var/lib/ifran/cache && \
    chown -R ifran:ifran /var/lib/ifran

# Copy arch-specific pre-built binaries
COPY bin/${TARGETARCH}/ifran-server /usr/local/bin/ifran-server
COPY bin/${TARGETARCH}/ifran /usr/local/bin/ifran

USER ifran
EXPOSE 8420 8421

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD ["/usr/local/bin/ifran", "status"] || exit 1

ENTRYPOINT ["tini", "--"]
CMD ["ifran-server"]

{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/elements/table.py",
  "productName": "Ifran",
  "identifier": "com.ifran.desktop",
  "build": {
    "frontendDist": "../src/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../src && npm run dev",
    "beforeBuildCommand": "cd ../src && npm run build"
  },
  "app": {
    "title": "Ifran",
    "windows": [
      {
        "title": "Ifran",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

# Ifran system configuration
# Installed to: /etc/ifran/ifran.toml
#
# For user-level config, use: ~/.ifran/ifran.toml
# Environment override: IFRAN_CONFIG=/path/to/ifran.toml

[server]
bind = "0.0.0.0:8420"
grpc_bind = "0.0.0.0:8421"

[storage]
# System-level paths (when running as systemd service)
models_dir = "/var/lib/ifran/models"
database = "/var/lib/ifran/ifran.db"
cache_dir = "/var/lib/ifran/cache"

[backends]
default = "llamacpp"
enabled = ["llamacpp", "candle", "ollama", "vllm", "gguf", "onnx", "tensorrt", "tpu", "gaudi", "inferentia", "oneapi", "qualcomm", "metal", "vulkan", "xdna"]

# Backend-specific configuration (optional)
# [backends.ollama]
# endpoint = "http://localhost:11434"
#
# [backends.vllm]
# endpoint = "http://localhost:8000"
#
# [backends.tensorrt]
# endpoint = "http://localhost:8000"
#
# [backends.tpu]
# endpoint = "http://localhost:8001"
#
# [backends.gaudi]
# endpoint = "http://localhost:8004"

[training]
executor = "docker"
trainer_image = "ghcr.io/maccracken/ifran-trainer:latest"
max_concurrent_jobs = 2
checkpoints_dir = "/var/lib/ifran/checkpoints"
# TTL (seconds) for completed/failed/cancelled jobs before eviction (0 = never, default: 86400 = 24h)
# job_eviction_ttl_secs = 86400

[bridge]
# SecureYeoman bridge (disabled by default)
# sy_endpoint = "http://localhost:9420"
enabled = false
heartbeat_interval_secs = 10

[hardware]
# Reserve VRAM (MB) for system use when loading models
gpu_memory_reserve_mb = 512
# GPU telemetry polling interval in seconds (0 = disabled)
# telemetry_interval_secs = 10

[security]
# Require IFRAN_API_KEY to be set (recommended for production)
auth_required = true
# Max request body size in bytes (10 MB)
max_body_size_bytes = 10485760
# Max prompt length in characters
max_prompt_length = 100000
# Per-IP rate limiting: requests per second / burst
rate_limit_per_second = 60
rate_limit_burst = 120
# CORS: restrict to specific origins in production
# cors_allowed_origins = ["https://your-domain.com"]
# Multi-tenant mode: per-tenant API keys and resource isolation
# Requires IFRAN_ADMIN_KEY for tenant management via /admin/tenants
# multi_tenant = false
# Require model storage on an encrypted volume
# require_encrypted_storage = false

[fleet]
# Fleet management for multi-node deployments (disabled by default)
# enabled = false
# Seconds without heartbeat before a node becomes Suspect
# suspect_timeout_secs = 30
# Seconds without heartbeat before a node becomes Offline
# offline_timeout_secs = 90
# Seconds between periodic health checks
# health_check_interval_secs = 15

[budget]
# GPU budget enforcement via Hoosh accounting (disabled by default)
# enabled = false
# hoosh_endpoint = "http://127.0.0.1:9401"
# Maximum GPU-hours per tenant per day (0 = unlimited)
# max_gpu_hours_per_day = 0

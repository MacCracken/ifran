# Synapse system configuration
# Installed to: /etc/synapse/synapse.toml
#
# For user-level config, use: ~/.synapse/synapse.toml
# Environment override: SYNAPSE_CONFIG=/path/to/synapse.toml

[server]
bind = "0.0.0.0:8420"
grpc_bind = "0.0.0.0:8421"

[storage]
# System-level paths (when running as systemd service)
models_dir = "/var/lib/synapse/models"
database = "/var/lib/synapse/synapse.db"
cache_dir = "/var/lib/synapse/cache"

[backends]
default = "llamacpp"
enabled = ["llamacpp", "candle", "ollama", "vllm", "gguf", "onnx", "tensorrt"]

# Backend-specific configuration (optional)
# [backends.ollama]
# endpoint = "http://localhost:11434"
#
# [backends.vllm]
# endpoint = "http://localhost:8000"
#
# [backends.tensorrt]
# endpoint = "http://localhost:8000"

[training]
executor = "docker"
trainer_image = "ghcr.io/maccracken/synapse-trainer:latest"
max_concurrent_jobs = 2
checkpoints_dir = "/var/lib/synapse/checkpoints"

[bridge]
# SecureYeoman bridge (disabled by default)
# sy_endpoint = "http://localhost:9420"
enabled = false
heartbeat_interval_secs = 10

[hardware]
# Reserve VRAM (MB) for system use when loading models
gpu_memory_reserve_mb = 512

[security]
# Require SYNAPSE_API_KEY to be set (recommended for production)
auth_required = true
# Max request body size in bytes (10 MB)
max_body_size_bytes = 10485760
# Max prompt length in characters
max_prompt_length = 100000
# Rate limiting: requests per second / burst
rate_limit_per_second = 60
rate_limit_burst = 120
# CORS: restrict to specific origins in production
# cors_allowed_origins = ["https://your-domain.com"]
# Multi-tenant mode: per-tenant API keys and resource isolation
# Requires SYNAPSE_ADMIN_KEY for tenant management via /admin/tenants
# multi_tenant = false
